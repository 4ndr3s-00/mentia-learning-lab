# puerto donde corre el backend de Node
PORT=3000

# datos de conexion a la base de datos postgres (usuario:password@host:puerto/nombre_bd)
DATABASE_URL=postgres://postgres:TU_PASSWORD@localhost:5432/mentia

# palabra secreta para firmar los tokens de sesion 
JWT_SECRET=cambia

# direccion del servicio de ia-analisis (ya viene corriendo en el puerto 8001)
IA_ANALISIS_URL=http://127.0.0.1:8001/analizar
